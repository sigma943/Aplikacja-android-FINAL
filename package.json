{
  "name": "pks-live",
  "version": "2.1.1",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npx cross-env NODE_ENV=production next build",
    "build:android:web": "npx cross-env NODE_ENV=production NEXT_OUTPUT_MODE=export next build && node scripts/prepare-android-web.mjs",
    "start": "next start",
    "lint": "eslint .",
    "update:route-shapes": "node scripts/update-route-shapes.mjs",
    "android:sync": "npm run build:android:web && npx cap sync android",
    "android:copy": "npx cap copy android",
    "android:open": "npx cap open android",
    "android:assets": "npx @capacitor/assets generate --android --assetPath assets --iconBackgroundColor \"#00A3A2\" --iconBackgroundColorDark \"#05070b\" --splashBackgroundColor \"#05070b\" --splashBackgroundColorDark \"#05070b\"",
    "android:build:debug": "cd android && gradlew.bat assembleDebug",
    "android:build:release": "cd android && gradlew.bat bundleRelease"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.3.4",
    "@capacitor/device": "^8.0.2",
    "@capacitor/network": "^8.0.1",
    "autoprefixer": "^10.4.21",
    "clsx": "^2.1.1",
    "firebase": "^12.12.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.553.0",
    "motion": "^12.23.24",
    "next": "^15.4.9",
    "postcss": "^8.5.6",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-leaflet": "^5.0.0",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.3.4",
    "@firebase/eslint-plugin-security-rules": "^0.0.2",
    "@tailwindcss/postcss": "4.1.11",
    "@tailwindcss/typography": "^0.5.19",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20.19.41",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^10.1.0",
    "eslint": "9.39.1",
    "eslint-config-next": "16.0.8",
    "firebase-tools": "^15.18.0",
    "puppeteer": "^24.42.0",
    "tailwindcss": "4.1.11",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.9.3"
  }
}
